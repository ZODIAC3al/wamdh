# MongoDB connection (required)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_DB_NAME=wamdh

# Django (required — generate with: python -c "import secrets; print(secrets.token_hex(32))")
DJANGO_SECRET_KEY=replace-with-a-50-char-random-string
DJANGO_SETTINGS_MODULE=config.settings.prod

# CORS — comma-separated list of your frontend origins
CORS_ORIGINS=https://wamdh.app,https://www.wamdh.app

# Your Railway/Render domain (set after deployment)
ALLOWED_HOST=your-app.up.railway.app

# Google Gemini API Key
GEMINI_API_KEY=

# HuggingFace Inference API Key
HF_API_KEY=

# Cloudinary Storage (for profile/banner photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ImageKit Storage (for PDF uploads)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Stripe Payments
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
